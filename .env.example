# Optional: App profile (test serves bundled web UI, api disables it)
APP_PROFILE=test

# Optional: Browser origins for API profile or cross-origin clients
ALLOWED_ORIGINS=

# Optional: Durable voice asset directory inside the container
VOICE_STORAGE_DIR=/data/voices

# Optional: Models to load — comma-separated (default: 1.7B)
MODEL_SIZES=1.7B

# Optional: Default model when client doesn't specify (default: 1.7B)
DEFAULT_MODEL_SIZE=1.7B

# Optional: Runtime mode / model selection at startup
INITIAL_MODE=voice_clone
INITIAL_CLONE_MODEL_SIZE=1.7B
VOICE_DESIGN_ENABLED=false
VOICE_DESIGN_MODEL_ID=Qwen/Qwen3-TTS-12Hz-1.7B-VoiceDesign
CLONE_0_6B_REPLICAS=2
CLONE_1_7B_REPLICAS=1
VOICE_DESIGN_REPLICAS=1

# Optional: Override the Hugging Face repo for each logical size
# Used by Docker build-time model download and runtime model selection.
MODEL_ID_0_6B=Qwen/Qwen3-TTS-12Hz-0.6B-Base
MODEL_ID_1_7B=Qwen/Qwen3-TTS-12Hz-1.7B-Base

# Optional: torch / loading configuration
MODEL_DEVICE=cuda
MODEL_DTYPE=bfloat16
ATTN_IMPLEMENTATION=sdpa
CUDA_GRAPH_MAX_SEQ_LEN=2048

# Optional: Streaming chunk size — codec steps per audio chunk (default: 2)
# Lower = faster first audio, higher = more efficient
# chunk_size=1 ~83ms/chunk, chunk_size=2 ~167ms/chunk
CHUNK_SIZE=2

# Optional: Max concurrent WebSocket connections (default: 8)
MAX_CONNECTIONS=8

# Optional: Additional synth requests allowed to wait for capacity (default: 1)
MAX_WAITING_SYNTH_REQUESTS=1

# Optional: Max input text length in characters (default: 5000)
MAX_TEXT_LENGTH=5000

# Optional: In-memory LRU size for cached reference audio / prompts (default: 32)
CLONE_PROMPT_CACHE_SIZE=32
