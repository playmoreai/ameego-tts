# Optional: Models to load — comma-separated (default: 0.6B,1.7B)
MODEL_SIZES=0.6B,1.7B

# Optional: Default model when client doesn't specify (default: 0.6B)
DEFAULT_MODEL_SIZE=0.6B

# Optional: Streaming chunk size — codec steps per audio chunk (default: 2)
# Lower = faster first audio, higher = more efficient
# chunk_size=1 ~83ms/chunk, chunk_size=2 ~167ms/chunk
CHUNK_SIZE=2

# Optional: Max concurrent WebSocket connections (default: 4)
MAX_CONNECTIONS=4
